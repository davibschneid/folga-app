iosApp/build/
iosApp/Pods/
iosApp/*.xcworkspace
xcuserdata/
*.xcuserstate
DerivedData/

# macOS
.DS_Store

# Firebase config
#   Both google-services.json and GoogleService-Info.plist are committed.
#   API keys inside are restricted by package / bundle ID + SHA-1 fingerprint
#   per Firebase docs, so they are safe to version alongside the source.

# Signing (release)
# *.jks / *.keystore / keystore.properties are generated by the developer and
# must NEVER be committed. In CI the upload keystore is restored from a
# base64-encoded GitHub Secret (see .github/workflows/android-release.yml).
*.jks
*.keystore
keystore.properties

# Environment
.env
.env.local

# Node (in case)
node_modules/
