rules_version = '2';

// Firebase Storage Security Rules do Easy Folgas.
//
// Hoje o único uso de Storage é a foto de perfil, gravada em
// `profile_photos/{uid}.jpg` por `FirebasePhotoStorageRepository`.
// Qualquer outro caminho é negado por padrão (default-deny da v2).
service firebase.storage {
  match /b/{bucket}/o {

    // Foto de perfil: leitura pública (precisa ser visível pra
    // outros usuários no avatar dos cards de troca / lista de
    // colegas) e escrita só pelo próprio dono — o nome do arquivo
    // tem que ser exatamente `{uid}.jpg`.
    match /profile_photos/{fileName} {
      allow read: if true;

      allow write: if request.auth != null
                   && fileName == request.auth.uid + '.jpg'
                   // Limite de 5 MB pra evitar upload acidental de
                   // foto de câmera de 30 MP do celular.
                   && request.resource.size < 5 * 1024 * 1024
                   // Aceita só imagens (image/jpeg, image/png, etc.).
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny — qualquer outro caminho é bloqueado.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
